/* pages/rank/index.wxss */
page {
  background-color: #f8f9fb;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* =========================================
   1. 头部背景
   ========================================= */
.header-bg {
  background: linear-gradient(135deg, #2D5CF6 0%, #4A7FFF 100%);
  padding-bottom: 100rpx;
}

.status-bar {
  height: env(safe-area-inset-top);
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
}

/* =========================================
   2. Tab 切换区域
   ========================================= */
.tab-section {
  margin: -60rpx 30rpx 0;
  position: relative;
  z-index: 10;
}

.tab-box {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  box-shadow: 0 8rpx 30rpx rgba(45, 92, 246, 0.15);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background-color: #2D5CF6;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.tab-sub {
  font-size: 22rpx;
  color: #999;
}

.tab-item.active .tab-text {
  color: #fff;
}

.tab-item.active .tab-sub {
  color: rgba(255, 255, 255, 0.7);
}

/* =========================================
   3. 排行榜内容区
   ========================================= */
.rank-content {
  flex: 1;
  padding: 30rpx;
}

/* 前三名展示 */
.top-three {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.top-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33.33%;
}

.top-item.first {
  transform: translateY(-20rpx);
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 6rpx;
  margin-bottom: 16rpx;
}

.avatar-wrap.gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.avatar-wrap.silver {
  background: linear-gradient(135deg, #E8E8E8 0%, #C0C0C0 100%);
}

.avatar-wrap.bronze {
  background: linear-gradient(135deg, #CD7F32 0%, #B87333 100%);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f0f4ff;
}

.rank-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  color: #fff;
}

.rank-badge.gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.rank-badge.silver {
  background: linear-gradient(135deg, #E8E8E8 0%, #A0A0A0 100%);
}

.rank-badge.bronze {
  background: linear-gradient(135deg, #CD7F32 0%, #8B4513 100%);
}

.crown {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 60rpx;
}

.top-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-count {
  font-size: 24rpx;
  color: #666;
}

.top-count.highlight {
  color: #2D5CF6;
  font-weight: 600;
  font-size: 28rpx;
}

/* =========================================
   4. 排名列表
   ========================================= */
.rank-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 120rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.list-sub {
  font-size: 22rpx;
  color: #999;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
  transition: background-color 0.2s;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-item.is-me {
  background-color: #fef9e6;
  margin: 0 -30rpx;
  padding: 24rpx 30rpx;
  border-radius: 12rpx;
}

.item-rank {
  width: 60rpx;
  text-align: center;
}

.rank-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #999;
}

.item-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 0 20rpx;
  background-color: #f0f4ff;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.item-sub {
  font-size: 22rpx;
  color: #999;
}

.item-count {
  display: flex;
  align-items: baseline;
}

.count-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #2D5CF6;
}

.count-unit {
  font-size: 24rpx;
  color: #2D5CF6;
  margin-left: 4rpx;
}

/* =========================================
   5. 我的排名（底部固定）
   ========================================= */
.my-rank {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.my-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.my-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background-color: #f0f4ff;
  border: 4rpx solid #2D5CF6;
}

.my-detail {
  display: flex;
  flex-direction: column;
}

.my-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.my-sub {
  font-size: 22rpx;
  color: #999;
}

.my-rank-num {
  display: flex;
  align-items: baseline;
  margin-right: 40rpx;
}

.my-rank-num .rank-label {
  font-size: 24rpx;
  color: #666;
}

.my-rank-num .rank-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2D5CF6;
  margin: 0 4rpx;
}

.my-count {
  display: flex;
  align-items: baseline;
}

.my-count .count-num {
  font-size: 36rpx;
}
