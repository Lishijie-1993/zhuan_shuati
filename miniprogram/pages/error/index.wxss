page {
  background-color: #ffffff;
  height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
}

/* 顶部区域 */
.error-header {
  background: linear-gradient(180deg, #2D5CF6 0%, #4A7FFF 100%); 
  padding-top: env(safe-area-inset-top);
  padding-bottom: 60rpx;
  color: #fff;
}

.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  position: relative;
}

.back-icon {
  font-size: 40rpx;
  font-weight: bold;
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  margin-right: 40rpx; /* 抵消左侧返回键宽度，使文字居中 */
}

/* 仪表盘统计 */
.stat-circle-wrapper {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.stat-circle {
  width: 320rpx;
  height: 320rpx;
  border: 4rpx border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  /* 模拟图片中的刻度感 */
  box-shadow: 0 0 0 10rpx rgba(255, 255, 255, 0.1);
}

.stat-num {
  font-size: 80rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 选项卡按钮 */
.tab-container {
  display: flex;
  justify-content: space-around;
  padding: 0 40rpx;
  margin-top: 30rpx;
}

.tab-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 28rpx;
}

.tab-btn.active {
  background: #ffffff;
  color: #2D5CF6;
  font-weight: bold;
}

/* 内容区域 */
.content-section {
  padding: 40rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 150rpx; 
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}