page {
  background-color: #f7f8fa;
  height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* =========================================
   1. 头部整体背景区域：渐变覆盖状态栏至 Tab 栏
   ========================================= */
.header-section {
  background: linear-gradient(180deg, #2D5CF6 0%, #4A7FFF 100%);
  padding-bottom: 40rpx;
}

/* 状态栏高度适配 */
.status-bar {
  height: env(safe-area-inset-top);
}

/* 自定义导航栏区域 */
.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  position: relative;
}

.back-btn {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  z-index: 10;
}

.back-icon {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.nav-title {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* =========================================
   2. 仪表盘统计区域
   ========================================= */
.stat-circle-wrapper {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 40rpx;
  /* 移除重复的背景设置 */
}

.stat-circle {
  width: 320rpx;
  height: 320rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 0 0 10rpx rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.1);
}

.stat-num {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* =========================================
   3. 选项卡切换
   ========================================= */
.tab-container {
  display: flex;
  justify-content: space-around;
  padding: 0 40rpx;
  /* 移除重复的背景设置 */
}

.tab-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 28rpx;
  color: #fff;
}

.tab-btn.active {
  background: #ffffff;
  color: #2D5CF6;
  font-weight: bold;
}

/* =========================================
   4. 内容列表区域
   ========================================= */
.content-section {
  flex: 1;
  padding: 40rpx 30rpx;
  background-color: #f7f8fa;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.error-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.error-q-type {
  margin-bottom: 10rpx;
}

.type-tag {
  background: #EEF3FF;
  color: #2D5CF6;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.error-q-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.error-q-info {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.arrow {
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 150rpx;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* =========================================
   5. 底部固定操作按钮
   ========================================= */
.action-bar {
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-retry {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #2D5CF6;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
}