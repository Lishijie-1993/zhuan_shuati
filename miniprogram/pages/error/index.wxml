<view class="container">
  <view class="error-header">
    <view class="nav-bar">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">〈</text>
      </view>
      <text class="page-title">我的错题</text>
    </view>

    <view class="stat-circle-wrapper">
      <view class="stat-circle">
        <view class="stat-num">0</view>
        <view class="stat-label">我的错题</view>
      </view>
    </view>

    <view class="tab-container">
      <view class="tab-btn {{activeTab === 'today' ? 'active' : ''}}" bindtap="switchTab" data-tab="today">今日错题</view>
      <view class="tab-btn {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部错题</view>
    </view>
  </view>

  <view class="content-section">
    <view class="section-header">
      <text class="section-title">按题型练习</text>
    </view>

    <view class="empty-state">
      <image src="/images/empty_error.png" class="empty-icon" mode="aspectFit"></image>
      <text class="empty-text">暂无数据</text>
    </view>
  </view>
</view>