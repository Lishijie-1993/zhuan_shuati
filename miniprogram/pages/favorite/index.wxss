/** pages/favorite/index.wxss **/
page {
  background-color: #ffffff;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden; 
}

/* 【修改点3】顶部安全适配：使用 flex 布局且动态计算 padding */
.header {
  background-color: #2D5CF6;
  color: #fff;
  padding-top: calc(env(safe-area-inset-top) + 10rpx); 
  padding-bottom: 20rpx;
  display: flex;
  align-items: center;
  position: relative;
  height: 88rpx; 
}

.back-icon {
  font-size: 44rpx;
  position: absolute;
  left: 30rpx;
  z-index: 10;
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.chapter-name {
  font-size: 34rpx;
  flex: 1;
  text-align: center;
  font-weight: 500;
}

.mode-switch {
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  border-bottom: 1rpx solid #f2f2f2;
}

.switch-container {
  display: flex;
  border: 2rpx solid #2D5CF6;
  border-radius: 40rpx; 
  overflow: hidden;
}

.mode-item {
  padding: 10rpx 40rpx;
  font-size: 26rpx;
  color: #2D5CF6;
}

.mode-item.active {
  background-color: #2D5CF6;
  color: #fff;
}

/* 【修改点3/5】高度适配：使用 flex:1 且 height:0 确保正确撑开 */
.quiz-swiper {
  flex: 1;
  width: 100%;
  height: 0; 
}

.quiz-content {
  height: 100%;
  /* 为底部导航留出足够空间，避免遮挡最后一段文字 */
  padding: 40rpx 40rpx 180rpx; 
  box-sizing: border-box;
}

/* 【修改点5】文本防截断处理 */
.question-text {
  font-size: 34rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 60rpx;
  text-align: justify;
  word-break: break-all;
  white-space: pre-wrap;
}

.option-item {
  background-color: #f6f7f9;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid transparent;
}

.option-label {
  flex: 1;
  margin-right: 20rpx;
  font-size: 30rpx;
  word-break: break-all;
}

/* 【修改点4】底部导航栏：添加足够的 padding-bottom 和安全区适配 */
.footer-actions {
  height: 110rpx;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: space-around;
  align-items: center;
  /* 基础内边距 + 底部安全区高度 */
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  position: fixed;
  bottom: 0;
  width: 100%;
  z-index: 100;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #2D5CF6;
  font-size: 22rpx;
  flex: 1;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D5CF6;
}
/* 空状态居中显示 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
  height: 60vh; /* 给它一个足够的高度，确保它能撑开页面 */
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}