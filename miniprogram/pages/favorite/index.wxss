/** pages/favorite/index.wxss **/
page {
  background-color: #ffffff;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 防止页面整体滚动，由内部scroll-view控制 */
}

/* 1. 顶部导航与模式切换 (复用 quiz 样式) */
.header {
  background-color: #2D5CF6;
  color: #fff;
  padding: 100rpx 30rpx 20rpx;
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  padding-right: 20rpx;
}

.chapter-name {
  font-size: 32rpx;
  flex: 1;
  text-align: center;
}

.mode-switch {
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  border-bottom: 1rpx solid #f2f2f2;
}

.switch-container {
  display: flex;
  border: 2rpx solid #2D5CF6;
  border-radius: 10rpx;
  overflow: hidden;
}

.mode-item {
  padding: 10rpx 40rpx;
  font-size: 28rpx;
  color: #2D5CF6;
}

.mode-item.active {
  background-color: #2D5CF6;
  color: #fff;
}

.auto-next {
  position: absolute;
  right: 30rpx;
  color: #2D5CF6;
  font-size: 28rpx;
}

/* 2. Swiper 容器适配 */
.quiz-swiper {
  flex: 1;
  width: 100%;
}

.quiz-content {
  height: 100%;
  padding: 40rpx 40rpx 120rpx; /* 为底部固定栏留出空间 */
  box-sizing: border-box;
}

/* 3. 题目内容样式 (复用 quiz 样式) */
.question-info {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.q-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.q-type-tag {
  background-color: #5d8aff;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 15rpx;
}

.question-text {
  font-size: 34rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 60rpx;
  text-align: justify;
}

/* 4. 选项列表样式 */
.option-item {
  background-color: #f6f7f9;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  color: #444;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item.active-correct {
  background-color: #f0f4ff;
  border-color: #2D5CF6;
  color: #2D5CF6;
}

.option-item.active-error {
  background-color: #fdf2f2;
  border-color: #FA5151;
  color: #FA5151;
}

.option-label {
  flex: 1;
  margin-right: 20rpx;
}

/* 5. 解析区块样式 */
.analysis-box {
  margin-top: 40rpx;
  padding-bottom: 60rpx;
}

.analysis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f2f2f2;
}

.analysis-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border-left: 8rpx solid #2D5CF6;
  padding-left: 20rpx;
}

.correct-answer-row {
  font-size: 30rpx;
  margin-bottom: 15rpx;
  color: #444;
}

.blue-text {
  color: #2D5CF6;
  font-weight: bold;
}

.analysis-detail {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  display: block;
  text-align: justify;
}

/* 6. 底部固定操作栏 */
.footer-actions {
  height: 110rpx;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #fff;
  position: fixed;
  bottom: 0;
  width: 100%;
  z-index: 100;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #2D5CF6;
  font-size: 22rpx;
  flex: 1;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D5CF6;
}

/* 7. 空状态样式 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  padding-bottom: 200rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
  opacity: 0.2;
}

.swipe-tip {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  margin: 40rpx 0;
}