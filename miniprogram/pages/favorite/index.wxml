<view class="container">
  <view class="header">
    <view class="back-icon" bindtap="goBack">〈</view>
    <text class="chapter-name">我的收藏</text>
  </view>

  <view class="mode-switch">
    <view class="switch-container">
      <view class="mode-item {{mode === 'answer' ? 'active' : ''}}" bindtap="switchMode" data-mode="answer">答题模式</view>
      <view class="mode-item {{mode === 'recite' ? 'active' : ''}}" bindtap="switchMode" data-mode="recite">背题模式</view>
    </view>
    <text class="auto-next" bindtap="toggleAutoNext">{{isAutoNext ? '自动' : '手动'}}</text>
  </view>

  <view wx:if="{{favorites.length === 0}}" class="empty-state">
    <image src="/images/icons/favorite2.png" class="empty-icon"></image>
    <text>收藏夹中暂无题目</text>
  </view>

  <swiper wx:else class="quiz-swiper" current="{{currentIndex}}" bindchange="onSwiperChange">
    <swiper-item wx:for="{{favorites}}" wx:key="id" wx:for-index="qIndex">
      <scroll-view scroll-y class="quiz-content">
        <view class="question-info">
          <text class="q-number">第{{qIndex + 1}}题</text>
          <view class="q-type-tag">{{item.type === 'single' ? '单选题' : (item.type === 'multiple' ? '多选题' : '判断题')}}</view>
        </view>

        <view class="question-text">{{item.questionText}}</view>

        <view class="options-list">
          <view 
            class="option-item {{ (mode === 'recite' && opt.id === item.correctAnswer) || (mode === 'answer' && userAnswers[item.id] !== null && opt.id === item.correctAnswer) ? 'active-correct' : '' }} {{ mode === 'answer' && userAnswers[item.id] !== null && opt.id !== item.correctAnswer && userAnswers[item.id] === opt.id ? 'active-error' : '' }}" 
            wx:for="{{item.options}}" 
            wx:for-item="opt"
            wx:key="id"
            bindtap="selectOption"
            data-opt-id="{{opt.id}}"
            data-q-id="{{item.id}}"
            data-index="{{qIndex}}"
          >
            <text class="option-label">{{opt.id}}. {{opt.text}}</text>
            <icon wx:if="{{ (mode === 'recite' && opt.id === item.correctAnswer) || (mode === 'answer' && userAnswers[item.id] !== null && opt.id === item.correctAnswer) }}" type="success" size="18" color="#07C160"></icon>
            <icon wx:if="{{ mode === 'answer' && userAnswers[item.id] !== null && opt.id !== item.correctAnswer && userAnswers[item.id] === opt.id }}" type="warn" size="18" color="#FA5151"></icon>
          </view>
        </view>

        <view class="analysis-box" wx:if="{{mode === 'recite' || userAnswers[item.id] || showAnalysisMap[item.id]}}">
          <view class="analysis-header">
            <text class="analysis-title">试题解析</text>
          </view>
          <view class="analysis-body">
            <view class="correct-answer-row">正确答案：<text class="blue-text">{{item.correctAnswer}}</text></view>
            <text class="analysis-detail">{{item.analysisText}}</text>
          </view>
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <view class="footer-actions" wx:if="{{favorites.length > 0}}">
    <view class="action-item" bindtap="prevQuestion">
      <image src="/images/icons/back.png" class="action-icon"></image>
      <text>上一题</text>
    </view>
    <view class="action-item" bindtap="onAnalysis">
      <image src="/images/icons/notes2.png" class="action-icon"></image>
      <text>解析</text>
    </view>
    <view class="action-item center">
      <text class="progress-text">{{currentIndex + 1}}/{{favorites.length}}</text>
    </view>
    <view class="action-item" bindtap="onFavorite">
      <image src="/images/icons/favorite.png" class="action-icon"></image>
      <text style="color: #ff9800;">已收藏</text>
    </view>
    <view class="action-item" bindtap="nextQuestion">
      <image src="/images/icons/next.png" class="action-icon"></image>
      <text>下一题</text>
    </view>
  </view>
</view>