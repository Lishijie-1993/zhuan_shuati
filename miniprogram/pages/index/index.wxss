/** miniprogram/pages/index/index.wxss **/
page {
  background-color: #f8f9fb;
}

.container {
  min-height: 100vh;
  background-color: #f8f9fb;
  padding-bottom: 30rpx;
}

/* 自定义导航栏 */
.header {
  background: linear-gradient(135deg, #2D5CF6 0%, #4A7FFF 100%);
}

.status-bar {
  height: env(safe-area-inset-top);
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
}

/* Banner 区域 */
.header-banner {
  width: 100%;
  height: 340rpx;
  background: linear-gradient(135deg, #2D5CF6 0%, #4A7FFF 100%);
  padding: 20rpx 40rpx 40rpx;
  display: flex;
  justify-content: space-between;
  box-sizing: border-box;
}

.banner-title {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  display: block;
}

.banner-subtitle {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 10rpx;
  display: block;
}

.banner-tag {
  margin-top: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 8rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  display: inline-block;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.banner-illustration {
  width: 200rpx;
  height: 200rpx;
}

/* 公告栏 */
.notice-bar {
  margin: -30rpx 30rpx 0;
  background: #fff;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.notice-label {
  color: #2D5CF6;
  font-weight: bold;
  font-size: 26rpx;
  margin-right: 20rpx;
  padding-right: 20rpx;
  border-right: 1rpx solid #eee;
}

.notice-swiper { flex: 1; height: 100%; }
.notice-item { line-height: 88rpx; font-size: 26rpx; color: #666; }

/* 菜单网格 */
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 40rpx 20rpx;
}

.menu-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.menu-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.menu-icon { width: 56rpx; height: 56rpx; }
.menu-name { font-size: 24rpx; color: #333; }

/* 大按钮 */
.main-actions {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  width: 48%;
  height: 160rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.btn-start {
  background: #ffffff;
  border: 2rpx solid #2D5CF6;
}

.btn-start .action-title { color: #2D5CF6; font-size: 34rpx; font-weight: bold; }
.btn-start .action-tip { color: rgba(45, 92, 246, 0.5); font-size: 20rpx; margin-top: 4rpx; }

.btn-exam {
  background: #2D5CF6;
  box-shadow: 0 10rpx 20rpx rgba(45, 92, 246, 0.2);
}

.btn-exam .action-title { color: #ffffff; font-size: 34rpx; font-weight: bold; }
.btn-exam .action-tip { color: rgba(255, 255, 255, 0.6); font-size: 20rpx; margin-top: 4rpx; }

/* 倒计时 */
.exam-countdown {
  margin: 0 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.exam-label { font-size: 24rpx; color: #999; }
.exam-days { margin-top: 8rpx; font-size: 30rpx; color: #333; }
.days-highlight { color: #2D5CF6; font-size: 40rpx; font-weight: bold; margin: 0 6rpx; }
.exam-arrow { font-size: 24rpx; color: #ccc; }