<view class="container">
  <!-- 文章内容区域 -->
  <scroll-view class="article-scroll" scroll-y>
    <!-- 封面图 -->
    <image class="cover-image" src="{{article.coverImage}}" mode="aspectFill"></image>
    
    <!-- 文章主体 -->
    <view class="article-content">
      <!-- 标题 -->
      <view class="article-title">{{article.title}}</view>
      
      <!-- 元信息 -->
      <view class="article-meta">
        <text class="meta-category">{{article.category}}</text>
        <text class="meta-date">{{article.publishTime}}</text>
        <text class="meta-views">阅读 {{article.views}}</text>
      </view>
      
      <!-- 分割线 -->
      <view class="divider"></view>
      
      <!-- 正文 -->
      <view class="article-body">
        <text class="article-text">{{article.content}}</text>
      </view>
      
      <!-- 相关推荐 -->
      <view class="related-section" wx:if="{{relatedArticles.length > 0}}">
        <view class="section-title">相关推荐</view>
        <view class="related-list">
          <view 
            class="related-item" 
            wx:for="{{relatedArticles}}" 
            wx:key="id"
            bindtap="goToArticle"
            data-id="{{item.id}}"
          >
            <image class="related-image" src="{{item.coverImage}}" mode="aspectFill"></image>
            <view class="related-info">
              <text class="related-title">{{item.title}}</text>
              <text class="related-time">{{item.publishTime}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="action-left">
      <view class="action-item" bindtap="toggleLike">
        <image class="action-icon" src="{{isLiked ? '/images/icons/like_active.png' : '/images/icons/like.png'}" mode="aspectFit"></image>
        <text class="action-text {{isLiked ? 'active' : ''}}">{{article.likes}}</text>
      </view>
      <view class="action-item" bindtap="shareArticle">
        <image class="action-icon" src="/images/icons/share.png" mode="aspectFit"></image>
        <text class="action-text">分享</text>
      </view>
    </view>
    <view class="action-right">
      <view class="collect-btn {{isCollected ? 'collected' : ''}}" bindtap="toggleCollect">
        <text>{{isCollected ? '已收藏' : '收藏'}}</text>
      </view>
    </view>
  </view>
</view>
