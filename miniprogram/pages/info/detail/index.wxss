/* pages/info/detail/index.wxss */
page {
  background-color: #fff;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 文章滚动区域 */
.article-scroll {
  flex: 1;
  padding-bottom: 120rpx;
}

/* 封面图 */
.cover-image {
  width: 100%;
  height: 480rpx;
  background-color: #f0f4ff;
}

/* 文章主体 */
.article-content {
  padding: 40rpx 30rpx;
}

/* 标题 */
.article-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 30rpx;
}

/* 元信息 */
.article-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}

.meta-category {
  font-size: 24rpx;
  color: #2D5CF6;
  background-color: #eef3ff;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
}

.meta-date,
.meta-views {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin-bottom: 40rpx;
}

/* 正文 */
.article-body {
  padding-bottom: 40rpx;
}

.article-text {
  font-size: 32rpx;
  color: #333;
  line-height: 2;
  text-align: justify;
}

/* 相关推荐 */
.related-section {
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 20rpx solid #f8f9fb;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 30rpx;
}

.related-list {
  display: flex;
  flex-direction: column;
}

.related-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.related-item:last-child {
  border-bottom: none;
}

.related-item:active {
  opacity: 0.7;
}

.related-image {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background-color: #f0f4ff;
  flex-shrink: 0;
}

.related-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.related-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.related-time {
  font-size: 24rpx;
  color: #999;
  margin-top: auto;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding: 0 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.action-left {
  display: flex;
  align-items: center;
}

.action-item {
  display: flex;
  align-items: center;
  margin-right: 50rpx;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

.action-text.active {
  color: #2D5CF6;
}

.collect-btn {
  background-color: #2D5CF6;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.collect-btn.collected {
  background-color: #f5f6f8;
  color: #999;
}
