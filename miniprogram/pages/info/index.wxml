<view class="container">
  <!-- 顶部搜索区域 -->
  <view class="search-section">
    <view class="search-box">
      <image class="search-icon" src="/images/icons/search.png" mode="aspectFit"></image>
      <input class="search-input" placeholder="搜索安全资讯..." placeholder-class="search-placeholder" bindconfirm="onSearch" confirm-type="search"/>
    </view>
  </view>

  <!-- 热门标签 -->
  <view class="tags-section">
    <scroll-view class="tags-scroll" scroll-x enable-flex>
      <view class="tag-item {{currentTag === '全部' ? 'active' : ''}}" bindtap="switchTag" data-tag="全部">全部</view>
      <view class="tag-item {{currentTag === '考试动态' ? 'active' : ''}}" bindtap="switchTag" data-tag="考试动态">考试动态</view>
      <view class="tag-item {{currentTag === '政策解读' ? 'active' : ''}}" bindtap="switchTag" data-tag="政策解读">政策解读</view>
      <view class="tag-item {{currentTag === '备考技巧' ? 'active' : ''}}" bindtap="switchTag" data-tag="备考技巧">备考技巧</view>
      <view class="tag-item {{currentTag === '行业资讯' ? 'active' : ''}}" bindtap="switchTag" data-tag="行业资讯">行业资讯</view>
      <view class="tag-item {{currentTag === '安全知识' ? 'active' : ''}}" bindtap="switchTag" data-tag="安全知识">安全知识</view>
    </scroll-view>
  </view>

  <!-- 资讯列表 -->
  <scroll-view class="news-list" scroll-y bindscrolltolower="loadMore">
    <view class="news-card" wx:for="{{newsList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="card-image" src="{{item.coverImage}}" mode="aspectFill" lazy-load></image>
      <view class="card-content">
        <view class="card-title">{{item.title}}</view>
        <view class="card-meta">
          <view class="meta-left">
            <text class="tag-badge">{{item.category}}</text>
            <text class="views">
              <text class="view-icon">👁</text>
              {{item.views}}
            </text>
          </view>
          <text class="publish-time">{{item.publishTime}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-more" wx:if="{{isLoading}}">
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{noMoreData && newsList.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty-state" wx:if="{{!isLoading && newsList.length === 0}}">
      <text>暂无资讯</text>
    </view>
  </scroll-view>
</view>
