<view class="container">
  <view class="custom-nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <image src="/images/icons/back.png" class="back-icon"></image>
      </view>
      <view class="nav-title">{{chapterTitle}}</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <view class="mode-switch">
    <view class="switch-container">
      <view class="mode-item {{mode === 'answer' ? 'active' : ''}}" bindtap="switchMode" data-mode="answer">答题模式</view>
      <view class="mode-item {{mode === 'recite' ? 'active' : ''}}" bindtap="switchMode" data-mode="recite">背题模式</view>
    </view>
    <text class="auto-next" bindtap="toggleAutoNext">{{isAutoNext ? '自动' : '手动'}}</text>
  </view>

  <scroll-view class="quiz-content" scroll-y>
    <view class="question-info">
      <text class="q-number">第{{currentIndex + 1}}题</text>
      <view class="q-type-tag">{{currentQuestionType === 'single' ? '单选题' : (currentQuestionType === 'multiple' ? '多选题' : '判断题')}}</view>
    </view>

    <view class="question-text">
      {{currentQuestionText}}
    </view>

    <view class="options-list">
      <view
        class="option-item {{ helper.isSelected(selectedSet, item.id) && (!userAnswer || hasSelected) ? 'selected' : '' }} {{ (mode === 'recite' && helper.isCorrect(item.id, correctAnswer)) || (mode === 'answer' && (userAnswer !== null || hasSubmitted) && helper.isCorrect(item.id, correctAnswer)) ? 'active-correct' : '' }} {{ mode === 'answer' && (userAnswer !== null || hasSubmitted) && helper.isCorrect(item.id, correctAnswer) === false && helper.isSelected(selectedSet, item.id) ? 'active-error' : '' }}"
        wx:for="{{options}}"
        wx:key="id"
        bindtap="selectOption"
        data-id="{{item.id}}"
      >
        <text class="option-label">{{item.id}}. {{item.text}}</text>

        <icon wx:if="{{ (mode === 'recite' && helper.isCorrect(item.id, correctAnswer)) || (mode === 'answer' && (userAnswer !== null || hasSubmitted) && helper.isCorrect(item.id, correctAnswer)) }}" type="success" size="18" color="#07C160"></icon>

        <icon wx:if="{{ mode === 'answer' && (userAnswer !== null || hasSubmitted) && helper.isCorrect(item.id, correctAnswer) === false && helper.isSelected(selectedSet, item.id) }}" type="warn" size="18" color="#FA5151"></icon>
      </view>
    </view>

    <view class="single-submit" wx:if="{{currentQuestionType !== 'multiple' && !userAnswer && userAnswers[currentQuestionId]}}">
      <button class="btn-submit" bindtap="confirmSingleChoice">确认答案</button>
    </view>

    <view class="multiple-submit" wx:if="{{currentQuestionType === 'multiple' && !userAnswer && hasSelected && userAnswers[currentQuestionId] && userAnswers[currentQuestionId].length > 0}}">
      <button class="btn-submit" bindtap="submitMultipleChoice">确认答案</button>
    </view>

    <view class="swipe-tip">
      {{currentQuestionType === 'multiple' ? '多选题' : '单选题'}}：点击选项{{currentQuestionType === 'multiple' ? '切换选中状态' : '选择答案'}}，确认后提交{{isAutoNext ? '，答对自动下一题' : ''}}
    </view>

    <view class="analysis-box" wx:if="{{mode === 'recite' || userAnswer || showAnalysis || hasSubmitted}}">
      <view class="analysis-header">
        <text class="analysis-title">试题解析</text>
        <text class="analysis-error" bindtap="onReportError">纠错</text>
      </view>
      <view class="analysis-body">
        <view class="correct-answer-row">
          正确答案：<text class="blue-text">{{correctAnswer}}</text>
        </view>
        <view class="ai-tag">✦ AI智能解析，仅供参考</view>
        <text class="analysis-detail">{{analysisText}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="footer-actions">
    <view class="action-item" bindtap="prevQuestion">
      <image src="/images/icons/back.png" class="action-icon"></image>
      <text>上一题</text>
    </view>
    <view class="action-item" bindtap="onAnalysis">
      <image src="/images/icons/notes2.png" class="action-icon"></image>
      <text>解析</text>
    </view>
    <view class="action-item center">
      <text class="progress-text">{{currentIndex + 1}}/{{totalQuestions}}</text>
    </view>

    <view class="action-item" bindtap="onFavorite">
      <image src="{{isFavorited ? '/images/icons/favorite.png' : '/images/icons/favorite2.png'}}" class="action-icon"></image>
      <text style="{{isFavorited ? 'color: #ff9800;' : ''}}">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>

    <view class="action-item" bindtap="nextQuestion">
      <image src="/images/icons/next.png" class="action-icon"></image>
      <text>下一题</text>
    </view>
  </view>
</view>

<wxs module="helper">
  module.exports = {
    // 兼容判断是否为数组（WXS 不支持 Array.isArray，使用 constructor 属性判断最为安全）
    isArray: function(value) {
      return toString.call(value) === '[object Array]';
    },
    // 检查选项是否被选中
    // selectedSet: 对象 { "A": true }，多选用
    // selectedSet: 字符串 'A'，单选用
    isSelected: function(selectedSet, optionId) {
      if (!selectedSet) return false;
      var normalizedId = typeof optionId === 'string' ? optionId.toUpperCase() : String(optionId).toUpperCase();
      // 字符串：单选答案
      if (typeof selectedSet === 'string') {
        return selectedSet.toUpperCase() === normalizedId;
      }
      // 对象：多选 selectedSet
      return !!(selectedSet[normalizedId] || selectedSet[optionId]);
    },
    // 检查选项是否正确答案（支持大小写不敏感比较，支持数字类型）
    isCorrect: function(optionId, correctAnswer) {
      if (!correctAnswer) return false;
      // 【修复4】统一转换为字符串再转大写，处理数字类型
      var normalizedOptionId = typeof optionId === 'string' ? optionId.toUpperCase() : String(optionId).toUpperCase();
      if (typeof correctAnswer === 'string') {
        if (correctAnswer.indexOf(',') > -1) {
          var parts = correctAnswer.split(',');
          for (var i = 0; i < parts.length; i++) {
            var part = parts[i];
            var normalizedPart = typeof part === 'string' ? part.trim().toUpperCase() : String(part).trim().toUpperCase();
            if (normalizedPart === normalizedOptionId) return true;
          }
          return false;
        }
        var normalizedCorrect = correctAnswer.toUpperCase();
        return normalizedCorrect === normalizedOptionId;
      }

      // 【修复1】数组处理：使用 WXS 兼容的 isArray 代替 Array.isArray
      if (module.exports.isArray(correctAnswer)) {
        try {
          for (var j = 0; j < correctAnswer.length; j++) {
            var item = correctAnswer[j];
            var normalizedItem = typeof item === 'string' ? item.toUpperCase() : String(item).toUpperCase();
            if (normalizedItem === normalizedOptionId) return true;
          }
          return false;
        } catch (e) {
          return false;
        }
      }

      return false;
    },
    // 检查用户是否选错了这个选项（不使用 this，避免 WXS 报错）
    isUserWrong: function(userAnswers, optionId) {
      if (userAnswers === undefined || userAnswers === null) return false;
      var normalizedOptionId = typeof optionId === 'string' ? optionId.toUpperCase() : String(optionId).toUpperCase();
      if (typeof userAnswers === 'string') {
        return userAnswers.toUpperCase() === normalizedOptionId;
      }

      // 【修复1】数组处理：使用 WXS 兼容的 isArray 代替 Array.isArray
      if (module.exports.isArray(userAnswers)) {
        try {
          for (var i = 0; i < userAnswers.length; i++) {
            var item = userAnswers[i];
            var normalizedItem = typeof item === 'string' ? item.toUpperCase() : String(item).toUpperCase();
            if (normalizedItem === normalizedOptionId) return true;
          }
          return false;
        } catch (e) {
          return false;
        }
      }

      return false;
    },
    // 简单的数组包含判断（用于 selectedOptions.indexOf 替代）
    arrayIncludes: function(arr, val) {
      if (arr === undefined || arr === null) return false;
      var normalizedVal = typeof val === 'string' ? val.toUpperCase() : String(val);
      try {
        for (var i = 0; i < arr.length; i++) {
          var item = arr[i];
          var normalizedItem = typeof item === 'string' ? item.toUpperCase() : String(item);
          if (normalizedItem === normalizedVal) return true;
        }
      } catch (e) {}
      return false;
    }
  }
</wxs>