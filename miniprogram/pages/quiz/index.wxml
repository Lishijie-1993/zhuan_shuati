<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <image src="/images/icons/back.png" class="back-icon"></image>
      </view>
      <view class="nav-title">{{chapterTitle}}</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 模式切换 -->
  <view class="mode-switch">
    <view class="switch-container">
      <view class="mode-item {{mode === 'answer' ? 'active' : ''}}" bindtap="switchMode" data-mode="answer">答题模式</view>
      <view class="mode-item {{mode === 'recite' ? 'active' : ''}}" bindtap="switchMode" data-mode="recite">背题模式</view>
    </view>
    <text class="auto-next" bindtap="toggleAutoNext">{{isAutoNext ? '自动' : '手动'}}</text>
  </view>

  <scroll-view class="quiz-content" scroll-y>
    <view class="question-info">
      <text class="q-number">第{{currentIndex + 1}}题</text>
      <view class="q-type-tag">{{questions[currentIndex].type === 'single' ? '单选题' : (questions[currentIndex].type === 'multiple' ? '多选题' : '判断题')}}</view>
    </view>

    <view class="question-text">
      {{currentQuestionText}}
    </view>

    <view class="options-list">
      <view
        class="option-item {{helper.isSelected(userAnswers[currentQuestionId], item.id) ? 'selected' : ''}} {{ (mode === 'recite' && helper.isCorrect(item.id, correctAnswer)) || (mode === 'answer' && userAnswer !== null && helper.isCorrect(item.id, correctAnswer)) ? 'active-correct' : '' }} {{ mode === 'answer' && userAnswer !== null && helper.isCorrect(item.id, correctAnswer) === false && helper.isUserWrong(userAnswers[currentQuestionId], item.id) ? 'active-error' : '' }}"
        wx:for="{{options}}"
        wx:key="id"
        bindtap="selectOption"
        data-id="{{item.id}}"
      >
        <text class="option-label">{{item.id}}. {{item.text}}</text>

        <icon wx:if="{{ (mode === 'recite' && helper.isCorrect(item.id, correctAnswer)) || (mode === 'answer' && userAnswer !== null && helper.isCorrect(item.id, correctAnswer)) }}" type="success" size="18" color="#07C160"></icon>

        <icon wx:if="{{ mode === 'answer' && userAnswer !== null && helper.isCorrect(item.id, correctAnswer) === false && helper.isUserWrong(userAnswers[currentQuestionId], item.id) }}" type="warn" size="18" color="#FA5151"></icon>
      </view>
    </view>

    <!-- 多选题提交按钮 -->
    <view class="multiple-submit" wx:if="{{questions[currentIndex].type === 'multiple' && !userAnswer && userAnswers[currentQuestionId] && userAnswers[currentQuestionId].length > 0}}">
      <button class="btn-submit" bindtap="submitMultipleChoice">确认答案</button>
    </view>

    <view class="swipe-tip">
      {{questions[currentIndex].type === 'multiple' ? '多选题：点击选项切换选中状态，确认后提交' : '左右滑动可切换上下题'}}{{isAutoNext ? '，答对自动下一题' : ''}}
    </view>

    <view class="analysis-box" wx:if="{{mode === 'recite' || userAnswer}}">
      <view class="analysis-header">
        <text class="analysis-title">试题解析</text>
        <text class="analysis-error" bindtap="onReportError">纠错</text>
      </view>
      <view class="analysis-body">
        <view class="correct-answer-row">
          正确答案：<text class="blue-text">{{correctAnswer}}</text>
        </view>
        <view class="ai-tag">✦ AI智能解析，仅供参考</view>
        <text class="analysis-detail">{{analysisText}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="footer-actions">
    <view class="action-item" bindtap="prevQuestion">
      <image src="/images/icons/back.png" class="action-icon"></image>
      <text>上一题</text>
    </view>
    <view class="action-item" bindtap="onAnalysis">
      <image src="/images/icons/notes2.png" class="action-icon"></image>
      <text>解析</text>
    </view>
    <view class="action-item center">
      <text class="progress-text">{{currentIndex + 1}}/{{totalQuestions}}</text>
    </view>

    <view class="action-item" bindtap="onFavorite">
      <image src="{{isFavorited ? '/images/icons/favorite.png' : '/images/icons/favorite2.png'}}" class="action-icon"></image>
      <text style="{{isFavorited ? 'color: #ff9800;' : ''}}">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>

    <view class="action-item" bindtap="nextQuestion">
      <image src="/images/icons/next.png" class="action-icon"></image>
      <text>下一题</text>
    </view>
  </view>
</view>

<wxs module="helper">
  module.exports = {
    // 检查选项是否被选中
    isSelected: function(userAnswers, optionId) {
      if (!userAnswers) return false;
      if (typeof userAnswers === 'string') return userAnswers === optionId;
      // WXS 不支持 Array.isArray、toString、Object
      // 使用数组方法判断：数组有 indexOf 方法
      if (typeof userAnswers.indexOf === 'function') {
        return userAnswers.indexOf(optionId) > -1;
      }
      return false;
    },
    // 检查选项是否正确答案
    isCorrect: function(optionId, correctAnswer) {
      if (!correctAnswer) return false;
      if (typeof correctAnswer === 'string') {
        if (correctAnswer.indexOf(',') > -1) {
          var parts = correctAnswer.split(',');
          for (var i = 0; i < parts.length; i++) {
            if (parts[i].trim() === optionId) return true;
          }
          return false;
        }
        return correctAnswer === optionId;
      }
      // WXS 不支持 Array.isArray、toString、Object
      // 使用数组方法判断：数组有 indexOf 方法
      if (typeof correctAnswer.indexOf === 'function') {
        return correctAnswer.indexOf(optionId) > -1;
      }
      return false;
    },
    // 检查用户是否选错了这个选项
    isUserWrong: function(userAnswers, optionId) {
      return this.isSelected(userAnswers, optionId);
    }
  }
</wxs>