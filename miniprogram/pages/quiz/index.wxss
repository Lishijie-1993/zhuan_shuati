/** miniprogram/pages/quiz/index.wxss **/
page {
  background-color: #ffffff;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 */
.custom-nav {
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 20rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 20rpx;
}

.nav-placeholder {
  width: 64rpx;
}

/* 模式切换 */
.mode-switch {
  padding: 16rpx 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  background-color: #fff;
  border-bottom: 1rpx solid #f2f2f2;
}

.switch-container {
  display: flex;
  border: 2rpx solid #2D5CF6;
  border-radius: 10rpx;
  overflow: hidden;
}

.mode-item {
  padding: 10rpx 40rpx;
  font-size: 28rpx;
  color: #2D5CF6;
}

.mode-item.active {
  background-color: #2D5CF6;
  color: #fff;
}

/* 自动/手动 切换按钮 */
.auto-next {
  position: absolute;
  right: 30rpx;
  color: #2D5CF6;
  font-size: 28rpx;
  padding: 10rpx; /* 增加点击热区 */
  transition: opacity 0.2s;
}

.auto-next:active {
  opacity: 0.6;
}

/* 题目内容容器 */
.quiz-content {
  flex: 1;
  padding: 40rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.question-info {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.q-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 题型标签：蓝底白字 */
.q-type-tag {
  background-color: #5d8aff;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 15rpx;
}

.question-text {
  font-size: 34rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 60rpx;
  text-align: justify;
}

/* 选项列表 */
.option-item {
  background-color: #f6f7f9;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  color: #444;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid transparent; 
  transition: all 0.2s ease;
}

/* 正确选项：蓝色边框和浅蓝背景 (背题模式或答对时) */
.option-item.active-correct {
  background-color: #f0f4ff;
  border-color: #2D5CF6;
  color: #2D5CF6;
}

/* 错误选项：红色边框和浅红背景 (答题模式选错时) */
.option-item.active-error {
  background-color: #fdf2f2;
  border-color: #FA5151;
  color: #FA5151;
}

/* 多选题选中状态：紫色边框 */
.option-item.selected {
  background-color: #f5f0ff;
  border-color: #9c27b0;
  color: #9c27b0;
}

.option-label {
  flex: 1;
  margin-right: 20rpx;
}

/* 多选题提交按钮 */
.multiple-submit {
  text-align: center;
  margin: 30rpx 0;
}

.btn-submit {
  display: inline-block;
  padding: 20rpx 60rpx;
  background-color: #9c27b0;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.swipe-tip {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  margin: 60rpx 0;
}

/* 试题解析区块 */
.analysis-box {
  margin-top: 40rpx;
  padding-bottom: 120rpx;
}

.analysis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f2f2f2;
}

/* 解析标题：带有蓝色左边条 */
.analysis-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border-left: 8rpx solid #2D5CF6;
  padding-left: 20rpx;
  line-height: 1.1;
}

.analysis-error {
  font-size: 26rpx;
  color: #2D5CF6;
}

.analysis-body {
  padding: 10rpx 0;
}

.correct-answer-row {
  font-size: 30rpx;
  margin-bottom: 15rpx;
  color: #444;
}

.blue-text {
  color: #2D5CF6;
  font-weight: bold;
}

/* AI 标识：浅灰色 */
.ai-tag {
  font-size: 24rpx;
  color: #b0b0b0;
  margin-bottom: 20rpx;
}

.analysis-detail {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  display: block;
  text-align: justify;
}

/* 底部操作 */
.footer-actions {
  height: 110rpx;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #fff;
  position: fixed;
  bottom: 0;
  width: 100%;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #2D5CF6;
  font-size: 22rpx;
  flex: 1;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D5CF6;
}