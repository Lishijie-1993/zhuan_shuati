.container {
  padding: 0 !important;
  margin: 0 !important;
}
page { background-color: #f8f9fb; }

.history-header {
  background: linear-gradient(180deg, #2D5CF6 0%, #4A7FFF 100%); 
  padding-top: env(safe-area-inset-top);
  padding-bottom: 100rpx;
  color: #fff;
}

.nav-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.back-icon { font-size: 40rpx; font-weight: bold; }
.page-title { flex: 1; text-align: center; font-size: 34rpx; margin-right: 40rpx; }

/* 概览卡片样式 */
.stats-board {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  margin: 40rpx 30rpx 0;
  border-radius: 20rpx;
  padding: 30rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.border-line {
  border-left: 1rpx solid rgba(255, 255, 255, 0.2);
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-val { font-size: 40rpx; font-weight: bold; }
.stat-label { font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }

/* 记录列表样式 */
.list-section {
  margin-top: -60rpx;
  padding: 0 30rpx;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.exam-name { display: block; font-size: 30rpx; color: #333; font-weight: 500; margin-bottom: 10rpx; }
.exam-time { font-size: 24rpx; color: #999; }
.score-num { font-size: 44rpx; color: #2D5CF6; font-weight: bold; }
.score-unit { font-size: 24rpx; color: #2D5CF6; margin-left: 4rpx; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon { width: 240rpx; height: 240rpx; opacity: 0.5; margin-bottom: 20rpx; }
.empty-text { color: #999; font-size: 28rpx; }