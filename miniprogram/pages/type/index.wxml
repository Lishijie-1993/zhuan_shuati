<view class="container">
  <view class="header">
    <view class="status-bar"></view>
    
    <view class="nav-bar">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">〈</text>
      </view>
    </view>

    <view class="header-content">
      <view class="header-bg-icon">🎓</view>
      <text class="header-title">请选择题库分类</text>
    </view>
  </view>

  <view class="selection-section">
    <view class="select-card" bindtap="openPicker">
      <view class="dot"></view>
      <text class="card-text">{{selectedIndustry}}</text>
      <text class="arrow">〉</text>
    </view>
    
    <view class="select-card readonly-card">
      <view class="dot"></view>
      <text class="card-text">{{selectedType}} 《{{selectedIndustry}}》</text>
      <text class="arrow" style="opacity: 0;">〉</text> 
    </view>
  </view>

  <view class="divider">
    <view class="line"></view>
    <text class="divider-text">点击选择要进入的题库</text>
    <view class="line"></view>
  </view>

  <view class="chapter-grid">
    <view 
      class="grid-item" 
      wx:for="{{chapters}}" 
      wx:key="*this"
      bindtap="startQuiz"
      data-title="{{item}}"
    >
      {{item}}
    </view>
  </view>

  <view class="picker-modal" wx:if="{{showPicker}}">
    <view class="mask" bindtap="closePicker"></view>
    <view class="picker-content">
      <picker-view 
        indicator-style="height: 50px;" 
        style="width: 100%; height: 250px;" 
        value="{{pickerValue}}" 
        bindchange="onPickerChange"
      >
        <picker-view-column>
          <view 
            wx:for="{{industryOptions}}" 
            wx:key="*this" 
            style="line-height: 50px; text-align: center;"
            class="{{item === tempSelected ? 'picker-item-active' : 'picker-item-normal'}}"
          >
            {{item}}
          </view>
        </picker-view-column>
      </picker-view>
      
      <view class="picker-buttons">
        <button class="btn-cancel" bindtap="closePicker">取消</button>
        <button class="btn-confirm" bindtap="confirmSelection">确定</button>
      </view>
    </view>
  </view>
</view>