.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4A90E2 0%, #F7F8FA 40%);
  padding: 60rpx 30rpx;
  box-sizing: border-box;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
  margin-bottom: 60rpx;
}

.result-header {
  text-align: center;
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-label {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.score-circle.pass {
  background: linear-gradient(135deg, #07c160 0%, #5fc87a 100%);
}

.score-circle.fail {
  background: linear-gradient(135deg, #fa5151 0%, #ff7875 100%);
}

.score-num {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
}

.score-unit {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.pass-status {
  font-size: 32rpx;
  font-weight: bold;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  display: inline-block;
}

.pass-status.pass {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.pass-status.fail {
  background: rgba(250, 81, 81, 0.1);
  color: #fa5151;
}

.result-detail {
  padding-top: 40rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.detail-label {
  font-size: 30rpx;
  color: #666;
}

.detail-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-value.correct {
  color: #07c160;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-action {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #2D5CF6;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-action.secondary {
  background: #f8f8f8;
  color: #666;
}

.btn-action.outline {
  background: transparent;
  border: 2rpx solid #2D5CF6;
  color: #2D5CF6;
}
