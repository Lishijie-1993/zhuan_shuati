.container {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding: 0;
  padding-top: env(safe-area-inset-top);
}

.header-content {
  background: linear-gradient(135deg, #4A90E2 0%, #6AAEFF 100%);
  padding: 40rpx 30rpx 50rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-main {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.title-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.header-bg-icon {
  font-size: 80rpx;
}

.content-section {
  padding: 30rpx;
  margin-top: -20rpx;
}

.paper-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.paper-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-left {
  flex: 1;
}

.paper-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.paper-tags {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tag {
  background: #f0f4ff;
  color: #2D5CF6;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.score-tag {
  background: #fff7e6;
  color: #fa8c16;
}

.card-right {
  margin-left: 30rpx;
}

.start-btn {
  background: #2D5CF6;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.loading-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
