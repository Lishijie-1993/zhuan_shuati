.container { background-color: #f7f8fa; min-height: 100vh; padding: 20rpx; }
.header { margin-bottom: 30rpx; padding-left: 10rpx; border-left: 8rpx solid #2D5CF6; }
.title { font-size: 36rpx; font-weight: bold; color: #333; }

.paper-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.paper-title { font-size: 32rpx; font-weight: 500; color: #333; margin-bottom: 15rpx; }
.paper-meta { font-size: 24rpx; color: #999; display: flex; gap: 20rpx; }

.btn-start {
  background-color: #2D5CF6;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  margin: 0;
  line-height: 2;
}