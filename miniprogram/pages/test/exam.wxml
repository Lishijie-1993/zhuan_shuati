<view class="container">
  <!-- 使用系统导航栏，不重复添加返回按钮 -->

  <view class="status-bar">
    <view class="progress">
      <text class="current">{{currentIndex + 1}}</text>
      <text class="total">/{{questions.length}}</text>
    </view>
    <view class="timer {{timeLeft < 300 ? 'danger' : ''}}">
      <image class="icon-clock" src="/images/icons/clock.png" mode="aspectFit"></image>
      <text class="timer-text">{{timerText}}</text>
    </view>
  </view>

  <view class="question-card" wx:if="{{questions.length > 0}}">
    <view class="q-header">
      <text class="q-type">{{questions[currentIndex].type === 'single' ? '单选题' : (questions[currentIndex].type === 'multiple' ? '多选题' : '判断题')}}</text>
      <text class="q-score">分值：1分</text>
    </view>
    
    <view class="q-title">{{questions[currentIndex].title}}</view>

    <view class="options-group">
      <view
        wx:for="{{questions[currentIndex].options}}"
        wx:key="id"
        class="option-item {{helper.isSelected(userAnswers[questions[currentIndex].id], item.id) ? 'selected' : ''}}"
        bindtap="selectOption"
        data-key="{{item.id}}"
      >
        <view class="option-label">{{item.id}}</view>
        <view class="option-content">{{item.text}}</view>
      </view>
    </view>
  </view>

  <!-- 题库加载中或为空时的占位 -->
  <view wx:if="{{questions.length === 0}}" class="loading-placeholder">
    <text>题目加载中...</text>
  </view>

  <view class="footer">
    <button class="btn-nav" bindtap="prevQuestion" disabled="{{currentIndex === 0}}">上一题</button>
    
    <button wx:if="{{currentIndex === questions.length - 1}}" class="btn-submit" bindtap="submitExam">提交试卷</button>
    <button wx:else class="btn-nav primary" bindtap="nextQuestion">下一题</button>
  </view>
</view>

<wxs module="helper">
  module.exports = {
    isSelected: function(userAns, id) {
      if (!userAns) return false;
      if (typeof userAns === 'string') return userAns === id;
      if (Array.isArray(userAns)) return userAns.indexOf(id) > -1;
      return false;
    }
  }
</wxs>