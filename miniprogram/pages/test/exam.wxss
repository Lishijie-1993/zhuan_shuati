.container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
}

.progress .current { font-size: 44rpx; font-weight: bold; color: #333; }
.progress .total { font-size: 26rpx; color: #999; }

.timer {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  font-family: 'Courier New', Courier, monospace;
  font-weight: bold;
}
.timer.danger { color: #fa5151; animation: blink 1s infinite; }
@keyframes blink { 50% { opacity: 0.6; } }

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  min-height: 70vh;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.02);
}

.q-header { display: flex; justify-content: space-between; margin-bottom: 30rpx; }
.q-type { background: #EEF3FF; color: #2D5CF6; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.q-score { color: #ccc; font-size: 22rpx; }

.q-title {
  font-size: 34rpx;
  color: #333;
  line-height: 1.6;
  font-weight: 500;
  margin-bottom: 50rpx;
}

/* 选项样式 */
.option-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  transition: all 0.2s ease;
}

.option-label {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f8f8f8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-weight: bold;
  color: #666;
}

.option-content { font-size: 30rpx; color: #444; flex: 1; }

/* 选中状态 */
.option-item.selected {
  background: rgba(0,122,255,0.05);
  border-color: #2D5CF6;
}
.option-item.selected .option-label {
  background: #2D5CF6;
  color: #fff;
}
.option-item.selected .option-content {
  color: #2D5CF6;
  font-weight: 500;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx 60rpx;
  display: flex;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.btn-nav {
  width: 45%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  background: #f8f8f8;
  color: #666;
}

.btn-nav.primary {
  background: #2D5CF6;
  color: #fff;
}

.btn-submit {
  width: 45%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
}