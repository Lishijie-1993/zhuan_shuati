/* pages/medals/index.wxss */
page {
  background-color: #f8f9fb;
}

.container {
  min-height: 100vh;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #2D5CF6 0%, #4A7FFF 100%);
}

.status-bar {
  height: env(safe-area-inset-top);
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.back-btn {
  padding: 10rpx;
}

.back-icon {
  font-size: 44rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 统计栏 */
.stats-bar {
  margin: -50rpx 30rpx 0;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(45, 92, 246, 0.1);
  position: relative;
  z-index: 10;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #2D5CF6;
}

.stats-label {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #eee;
}

/* 勋章网格 */
.medals-grid {
  padding: 30rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.medal-item {
  width: 48%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx 20rpx 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.medal-item:active {
  transform: scale(0.96);
}

.medal-item.locked {
  background-color: #f5f5f5;
}

.medal-icon-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.medal-icon {
  width: 120rpx;
  height: 120rpx;
}

.medal-item.locked .medal-icon {
  opacity: 0.3;
}

.medal-glow {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.3) 0%, transparent 70%);
  animation: glow 2s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.2); opacity: 0.8; }
}

.medal-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.medal-item.locked .medal-name {
  color: #999;
}

.medal-desc {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  line-height: 1.4;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.detail-content {
  width: 80%;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.detail-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.detail-condition {
  width: 100%;
  background-color: #f8f9fb;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.condition-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.condition-text {
  font-size: 28rpx;
  color: #333;
}

.detail-progress {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: #eee;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2D5CF6 0%, #4A7FFF 100%);
  border-radius: 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #2D5CF6;
}

.detail-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.detail-close {
  width: 100%;
  background: linear-gradient(135deg, #2D5CF6 0%, #4A7FFF 100%);
  border-radius: 44rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-close text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}
