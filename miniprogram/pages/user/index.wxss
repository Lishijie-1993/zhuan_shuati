/* pages/user/index.wxss */
page {
  background-color: #f8f9fb;
}

.container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* =========================================
   1. 用户头部区域
   ========================================= */
.user-header {
  background: linear-gradient(135deg, #2D5CF6 0%, #4A7FFF 100%);
  padding-bottom: 60rpx;
}

.status-bar {
  height: env(safe-area-inset-top);
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: #f0f4ff;
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.edit-btn {
  padding: 12rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.edit-btn text {
  font-size: 24rpx;
  color: #fff;
}

/* =========================================
   2. 学习数据统计
   ========================================= */
.stats-section {
  margin: -30rpx 30rpx 0;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 30rpx rgba(45, 92, 246, 0.12);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #2D5CF6;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #eee;
}

/* 【修复7】刷题记录进度条 */
.progress-section {
  margin: 30rpx 30rpx 0;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(45, 92, 246, 0.08);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.progress-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.progress-subtitle {
  font-size: 26rpx;
  color: #2D5CF6;
  font-weight: 500;
}

.progress-bar-container {
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 24rpx;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
}

.progress-correct {
  height: 100%;
  background: linear-gradient(90deg, #07C160 0%, #10B981 100%);
  border-radius: 12rpx 0 0 12rpx;
  transition: width 0.3s ease;
}

.progress-wrong {
  height: 100%;
  background: linear-gradient(90deg, #FA5151 0%, #FF6B6B 100%);
  border-radius: 0 12rpx 12rpx 0;
  transition: width 0.3s ease;
}

.progress-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.legend-dot.correct {
  background-color: #07C160;
}

.legend-dot.wrong {
  background-color: #FA5151;
}

.legend-text {
  font-size: 26rpx;
  color: #666;
}

/* =========================================
   3. 功能菜单区域
   ========================================= */
.menu-section {
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.menu-group {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f8f8f8;
}

/* 【修复8】去除按钮默认样式，让 <button> 完全适配 .menu-item 布局 */
.menu-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  border-radius: 0;
  /* 让按钮宽度撑满父容器 */
  width: 100%;
  /* 确保 flex 布局正常工作 */
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  /* 匹配 .menu-item 的垂直内边距，使高度与同组其他项一致 */
  padding: 32rpx 30rpx;
  box-sizing: border-box;
}

.menu-btn::after {
  border: none;
}

.menu-btn:active {
  background-color: #f8f8f8;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-badge {
  font-size: 22rpx;
  color: #fff;
  background-color: #ff6b35;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* =========================================
   4. 退出登录
   ========================================= */
.logout-section {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.logout-btn {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn text {
  font-size: 30rpx;
  color: #FA5151;
}

.logout-btn:active {
  background-color: #fdf2f2;
}
