/* pages/settings/index.wxss */
page {
  background-color: #f8f9fb;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #2D5CF6 0%, #4A7FFF 100%);
}

.status-bar {
  height: env(safe-area-inset-top);
}

.nav-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.back-btn {
  padding: 10rpx;
}

.back-icon {
  font-size: 44rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 设置内容 */
.settings-content {
  flex: 1;
  padding: 20rpx 30rpx;
}

/* 设置分组 */
.settings-group {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 30rpx 10rpx;
  background-color: #f8f9fb;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background-color: #f8f8f8;
}

.setting-left {
  display: flex;
  align-items: center;
}

.setting-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.setting-text {
  font-size: 30rpx;
  color: #333;
}

.setting-right {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 10rpx;
}

.setting-value.version {
  color: #2D5CF6;
}

.arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 开关样式 */
switch {
  transform: scale(0.85);
}

/* 底部 */
.footer {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-text {
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 8rpx;
}

.footer-sub {
  font-size: 22rpx;
  color: #ddd;
}
