<view class="container">
  <scroll-view class="nav-left" scroll-y>
    <view
      class="nav-item {{activeCategory === index ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="name"
      bindtap="switchCategory"
      data-index="{{index}}"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <scroll-view class="nav-right" scroll-y>
    <view class="content-wrapper">
      <view class="category-header">
        <view class="dot"></view>
        <text class="category-main-title">{{categories[activeCategory].type}} 《{{categories[activeCategory].name}}》</text>
      </view>

      <view class="chapter-box">
        <view
          class="chapter-item"
          wx:for="{{categories[activeCategory].chapters}}"
          wx:key="*this"
          bindtap="startQuiz"
          data-title="{{item}}"
        >
          <text class="chapter-title">{{item}}</text>
          <view class="go-btn">GO</view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{categories[activeCategory].chapters.length === 0}}">
        <text>暂无内容，敬请期待</text>
      </view>
    </view>
  </scroll-view>
</view>