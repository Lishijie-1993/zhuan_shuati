/* miniprogram/pages/category/index.wxss */

page {
  background-color: #ffffff;
  height: 100%;
  overflow: hidden;
}

.container {
  display: flex;
  height: 100vh;
  width: 100%;
}

/* 左侧导航区域 */
.nav-left {
  width: 220rpx;
  background-color: #f7f7f7;
  height: 100%;
}

.nav-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666666;
  padding: 0 20rpx;
  text-align: center;
  transition: all 0.2s ease;
}

/* 激活状态：白色背景 + 蓝色左边框 + 蓝色文字 */
.nav-item.active {
  background-color: #ffffff;
  color: #2D5CF6;
  font-weight: bold;
  border-left: 8rpx solid #2D5CF6;
}

/* 右侧内容区域 */
.nav-right {
  flex: 1;
  height: 100%;
  background-color: #ffffff;
}

.content-wrapper {
  padding: 0 30rpx 40rpx;
}

/* 右侧标题区：对齐截图中的圆点样式 */
.category-header {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  margin-bottom: 10rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #2D5CF6;
  border-radius: 50%;
  margin-right: 15rpx;
}

.category-main-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

/* 章节列表项 */
.chapter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.chapter-title {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.5;
}

/* GO 按钮：对齐截图中的淡蓝色圆角样式 */
.go-btn {
  width: 84rpx;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  background-color: #f0f4ff;
  color: #2D5CF6;
  border-radius: 23rpx;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0; /* 防止标题过长时按钮被挤压 */
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  color: #999999;
  font-size: 26rpx;
}