/* 确保页面高度占满全屏 */
page {
  background-color: #ffffff;
  height: 100%;
  overflow: hidden;
}

/* 主容器：使用 Flex 布局让左右并排 */
.container {
  display: flex;
  height: 100vh;
  width: 100%;
}

/* 左侧栏 */
.nav-left {
  width: 220rpx;
  background-color: #f7f7f7;
  height: 100%;
}

.nav-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666666;
  padding: 0 20rpx;
  text-align: center;
}

/* 激活态样式：左侧蓝色边框 */
.nav-item.active {
  background-color: #ffffff;
  color: #2D5CF6;
  font-weight: bold;
  border-left: 8rpx solid #2D5CF6;
}

/* 右侧内容区 */
.nav-right {
  flex: 1;
  height: 100%;
  background-color: #ffffff;
}

/* 内部间距包裹 */
.content-wrapper {
  padding: 0 30rpx 40rpx;
}

/* 标题区域 */
.category-header {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  margin-bottom: 10rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #2D5CF6;
  border-radius: 50%;
  margin-right: 15rpx;
}

.category-main-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

/* 章节项布局：标题在左，GO按钮在右 */
.chapter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.chapter-title {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.5;
}

/* GO 按钮样式 */
.go-btn {
  width: 84rpx;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  background-color: #f0f4ff;
  color: #2D5CF6;
  border-radius: 23rpx;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  color: #999999;
  font-size: 26rpx;
}